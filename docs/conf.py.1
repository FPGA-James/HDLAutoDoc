# conf.py — Sphinx configuration for VHDL traffic light documentation

import os
import sys

# ── Project metadata ─────────────────────────────────────────────────────────
project   = "Traffic Light Controller"
author    = "HDL Team"
copyright = "2026, HDL Team"
release   = "1.0.0"

# ── Extensions ───────────────────────────────────────────────────────────────
extensions = [
    # Core Sphinx
    "sphinx.ext.autodoc",
    "sphinx.ext.viewcode",
    "sphinx.ext.graphviz",        # renders .dot files / inline dot directives

    # WaveDrom — multiple diagrams per file via .. wavedrom:: directive
    "sphinxcontrib.wavedrom",

    # HDL diagrams via Yosys (block/netlist diagrams for Verilog)
    # "sphinxcontrib.hdl_diagrams",  # uncomment if yosys is installed

    # VHDL domain — cross-references, auto-doc from source
    "sphinxvhdl.vhdl",             # pip install sphinx-vhdl
]

# ── WaveDrom config ───────────────────────────────────────────────────────────
# Use online CDN — no Node.js required for HTML builds
# For offline/PDF builds, switch to wavedrompy:
#   wavedrom_use_wavedrompy = True
wavedrom_html_jsinline = False      # load WaveDrom from CDN
online_wavedrom_js_url  = "https://cdnjs.cloudflare.com/ajax/libs/wavedrom/3.3.0/wavedrom.min.js"
online_skin_js_url      = "https://cdnjs.cloudflare.com/ajax/libs/wavedrom/3.3.0/skins/default.js"

# ── HTML output ───────────────────────────────────────────────────────────────
html_theme   = "sphinx_rtd_theme"   # pip install sphinx-rtd-theme
html_static_path = ["_static"]
html_css_files   = ["custom.css"]

# ── Graphviz (FSM diagrams rendered as SVG) ──────────────────────────────────
graphviz_output_format = "svg"

# ── sphinx-vhdl settings ─────────────────────────────────────────────────────
vhdl_autodoc_source_path = os.path.abspath("../src")   # where to scan for .vhd files

# ── Source ────────────────────────────────────────────────────────────────────
source_suffix  = ".rst"
master_doc     = "index"
exclude_patterns = ["_build", "Thumbs.db", ".DS_Store"]