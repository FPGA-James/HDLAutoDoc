digraph pwm_controller_block {
    rankdir=LR;
    nodesep=0.5;
    ranksep=0.8;
    node [fontname="Helvetica", fontsize=12, shape=none, margin=0];
    edge [dir=none, penwidth=2.5, color="black"];

    // Generics box
    gen_box_pwm_controller [label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="3" CELLPADDING="0" BGCOLOR="#c8f5c4" COLOR="#1a5c1a">
          <TR><TD PORT="g_WIDTH" ALIGN="LEFT" CELLPADDING="5">WIDTH = 8</TD></TR>
        </TABLE>>];

    // Ports box
    port_box_pwm_controller [label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="3" CELLPADDING="0" BGCOLOR="#fffde7" COLOR="#5d4200">
          <TR><TD PORT="i_clk" ALIGN="LEFT" CELLPADDING="5">&#x25B8; clk</TD><TD WIDTH="50"> </TD><TD PORT="o_pwm_o" ALIGN="RIGHT" CELLPADDING="5">pwm_o &#x25C2;</TD></TR>
          <TR><TD PORT="i_rst" ALIGN="LEFT" CELLPADDING="5">&#x25B8; rst</TD><TD WIDTH="50"> </TD><TD PORT="o_period_done" ALIGN="RIGHT" CELLPADDING="5">period_done &#x25C2;</TD></TR>
          <TR><TD PORT="i_en" ALIGN="LEFT" CELLPADDING="5">&#x25B8; en</TD><TD WIDTH="50"> </TD><TD CELLPADDING="5"> </TD></TR>
          <TR><TD PORT="i_duty_i" ALIGN="LEFT" CELLPADDING="5">&#x25B8; duty_i [WIDTH-1:0]</TD><TD WIDTH="50"> </TD><TD CELLPADDING="5"> </TD></TR>
        </TABLE>>];

    { rank=same; gen_box_pwm_controller; port_box_pwm_controller }
    gen_box_pwm_controller -> port_box_pwm_controller [style=invis, weight=100];

}